# =============================================================================
# tagsha — Stack Environment Variables
#
# Copy this file to stack.env, fill in your values, then load it in Portainer:
#   Stacks > your stack > Editor > "Load variables from .env file"
#
# DO NOT commit stack.env to version control (it is gitignored).
# See docs/deployment.md for full instructions.
# =============================================================================

# --- Image version -----------------------------------------------------------
# Pin to a release tag (e.g. v0.0.5) for production stability.
# Use 'latest' to always pull the most recent build.
TAGSHA_VERSION=latest

# --- GitHub Token (optional) -------------------------------------------------
# Without a token the GitHub API allows 60 unauthenticated requests per hour.
# Providing a token raises this to 5,000 req/hr and enables private repo access.
#
# To create a token:
#   GitHub > Settings > Developer settings > Personal access tokens > Fine-grained
#   Required scopes: Contents (read-only) on public repositories
#
# Leave blank to run without a token:
TAGSHA_GITHUB_TOKEN=

# --- API tuning --------------------------------------------------------------
TAGSHA_ENV=production
TAGSHA_LOG_LEVEL=info
TAGSHA_CACHE_TTL_SECONDS=300
TAGSHA_RATE_LIMIT_RPM=60
TAGSHA_MAX_PAGES=10

# --- Domain ------------------------------------------------------------------
# Set to your hostname or IP if deploying behind a reverse proxy.
TAGSHA_DOMAIN=localhost

# --- Frontend port -----------------------------------------------------------
# Host port the frontend will be accessible on.
TAGSHA_FRONTEND_PORT=3000
