# TagSha Environment Configuration
# Copy to .env and fill in values. NEVER commit .env to git.

# =============================================================
# SERVER
# =============================================================
TAGSHA_PORT=8080
TAGSHA_ENV=production
TAGSHA_LOG_LEVEL=info

# =============================================================
# GITHUB API
# =============================================================
# Optional but strongly recommended — raises rate limit from
# 60/hour (unauthenticated) to 5000/hour (authenticated).
# Store as Docker secret in production: ./secrets/github_token
# TAGSHA_GITHUB_TOKEN=ghp_your_token_here

# =============================================================
# REDIS
# =============================================================
TAGSHA_REDIS_URL=redis://redis:6379/0

# =============================================================
# CACHING
# =============================================================
TAGSHA_CACHE_TTL_SECONDS=300
TAGSHA_MAX_PAGES=10

# =============================================================
# RATE LIMITING
# =============================================================
TAGSHA_RATE_LIMIT_RPM=50

# =============================================================
# DOMAIN (for Caddy TLS)
# =============================================================
TAGSHA_DOMAIN=tagsha.yourdomain.com

# =============================================================
# GRAFANA (set as Docker secret in production)
# =============================================================
# GF_SECURITY_ADMIN_PASSWORD=changeme
